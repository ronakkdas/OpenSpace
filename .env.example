# Copy this file to .env.local and fill in the real values.
# See STRIPE_SETUP.md for where to find each Stripe value.

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# --- Stripe ---
# Test mode keys start with sk_test_ / pk_test_ / price_
STRIPE_SECRET_KEY=sk_test_placeholder
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_placeholder
STRIPE_PRO_PRICE_ID=price_placeholder
# From `stripe listen` CLI output, or the Stripe Dashboard webhook settings
STRIPE_WEBHOOK_SECRET=whsec_placeholder
